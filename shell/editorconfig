root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,gradle,groovy}]
indent_size = 4

[*.{js,ts,jsx,tsx,json,yaml,yml}]
indent_size = 2

[*.py]
indent_size = 4

[package.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2